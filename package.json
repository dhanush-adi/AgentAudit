{
  "name": "agentaudit-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "eslint '**/*.{ts,tsx}' --no-error-on-unmatched-pattern",
    "lint:fix": "eslint '**/*.{ts,tsx}' --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "typecheck": "turbo typecheck",
    "dev:frontend": "cd Frontend && pnpm dev",
    "dev:demo": "cd packages/demo-agent && pnpm dev",
    "dev:contracts": "cd packages/contracts && pnpm hardhat node"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "5.7.3"
  }
}
