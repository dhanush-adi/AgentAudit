# ╔══════════════════════════════════════════════════════════════╗
# ║  AgentAudit Environment Variables                           ║
# ║  Copy this file to .env and fill in your values            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Wallet & Keys ─────────────────────────────────────────────

# EVM Wallet Private Key for deployment and agent operations
# WARNING: Never commit your real private key. Use testnet keys only for development.
# Must have test BTC on GOAT Testnet3 for contract deployment.
PRIVATE_KEY=your_private_key_here

# Telegram Bot Token from BotFather (optional, for Telegram integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (optional, for AI model access)
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Network & RPC ─────────────────────────────────────────────

# GOAT Network RPC endpoint
GOAT_RPC_URL=https://rpc.testnet3.goat.network

# ── Frontend ──────────────────────────────────────────────────

# URL of the demo-agent API server (used by the dashboard frontend)
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001

# On-chain contract addresses (update if redeploying contracts)
NEXT_PUBLIC_AGENT_REGISTRY=0x3de03AB80fdDDa888598303FF34E496bD29E140F
NEXT_PUBLIC_REPUTATION_REGISTRY=0x4721bEF3A4A7226E63783d6546031eCEe3D59BF0
NEXT_PUBLIC_VALIDATION_REGISTRY=0x9facA0523F1CEc547CE5e00a808338bF67a46924

# ── Demo Agent ────────────────────────────────────────────────

# Address that receives micropayments from API callers
RECEIVING_ADDRESS=0x2962B9266a48E8F83c583caD27Be093f231781b8

# Comma-separated list of allowed CORS origins (default: * for dev)
CORS_ORIGINS=*

# ── Middleware ─────────────────────────────────────────────────

# Custom x402 facilitator URL (default: https://x402.org/facilitator)
X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Deployment ────────────────────────────────────────────────

# Vercel deployment tokens (used by CI/CD, not needed for local dev)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
